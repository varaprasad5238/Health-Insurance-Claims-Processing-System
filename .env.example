# Root-level reference for local development.
# Copy relevant values into backend/.env and frontend/.env.local if you prefer per-app env files.

# Backend API
API_BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

# Frontend public API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# LLM provider: stub | gemini | openai
LLM_PROVIDER=stub
USE_STUB_LLM=true

# Primary model
VISION_MODEL=gpt-5.5

# Fallback model. Provider can be different from primary provider.
FALLBACK_LLM_PROVIDER=gemini
FALLBACK_VISION_MODEL=gemini-2.5-pro

# Gemini configuration. Required only when using Gemini.
GEMINI_API_KEY=

# OpenAI configuration. Required only when using OpenAI.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

FAST_MODEL=gemini-2.5-flash
LLM_TIMEOUT_SECONDS=45
LLM_MAX_RETRIES=1
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_COOLDOWN_SECONDS=60